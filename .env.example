# Environment Variables for SecureGuard Connect
# Copy this file to .env and update the values

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
PORT=5000
NODE_ENV=development

# JWT Secrets - MUST CHANGE IN PRODUCTION!
# Generate strong secrets using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production_min_32_chars

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=./server/database/secureguard.db

# Uploads Directory
UPLOADS_DIR=./uploads

# ===========================================
# PRODUCTION CONFIGURATION (Render/Heroku)
# ===========================================
# Uncomment and set these for production deployment:

# PORT=10000
# NODE_ENV=production
# CLIENT_URL=https://your-app-name.onrender.com
# JWT_SECRET=<generate-strong-secret-64-chars>
# JWT_REFRESH_SECRET=<generate-strong-secret-64-chars>
# DATABASE_URL=/opt/render/project/src/server/database/secureguard.db
# UPLOADS_DIR=/opt/render/project/src/uploads

# ===========================================
# SECURITY NOTES
# ===========================================
# 1. NEVER commit .env file to git
# 2. Use strong random secrets (minimum 32 characters)
# 3. Change default passwords after first login
# 4. Enable HTTPS in production
# 5. Set NODE_ENV=production for production deployments