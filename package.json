{
  "name": "secureguard-connect",
  "version": "1.0.0",
  "description": "WhatsApp-like Communication & Management Platform for Security Guard Agencies",
  "main": "server/index.js",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "seed": "node server/seedData.js",
    "credentials": "node server/showCredentials.js",
    "update-passwords": "node server/updatePasswords.js",
    "start": "node server/index.js",
    "heroku-postbuild": "cd client && npm install && npm run build",
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "echo \"No linting configured\" && exit 0"
  },
  "keywords": [
    "security",
    "guard",
    "management",
    "chat",
    "attendance",
    "real-time",
    "whatsapp",
    "communication",
    "workforce"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/secureguard-connect.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/secureguard-connect/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/secureguard-connect#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "socket.io": "^4.6.1",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
