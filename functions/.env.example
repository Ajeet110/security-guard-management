# Firebase Functions Environment Variables
# Copy this to .env and fill in your values

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-here-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here-change-this

# Client URL (your Firebase Hosting URL)
CLIENT_URL=https://your-project-id.web.app

# Database (Firebase will use Cloud Storage)
DATABASE_URL=/tmp/secureguard.db

# Uploads Directory (Firebase Storage)
UPLOADS_DIR=/tmp/uploads

# Node Environment
NODE_ENV=production
